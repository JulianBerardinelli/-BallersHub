# ============================================================
# 'BallersHub — environment variables (template)
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# ----- Supabase (existing) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ----- Database (Drizzle / Postgres) -----
DATABASE_URL=

# ----- Resend (email) -----
RESEND_API_KEY=

# ----- App -----
# Used to build success_url / back_urls — must match deployed URL in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Billing — Stripe (USD / EUR markets)
# ============================================================

# Server-only keys. Use restricted API keys (rk_...) in production with the
# minimum permissions required (Checkout, Customers, Subscriptions read/write).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional public key — only needed when integrating Stripe Elements client-side.
# The hosted Checkout flow we use today does NOT require this.
STRIPE_PUBLISHABLE_KEY=

# Pre-provisioned Stripe Prices (yearly, recurring). Format:
#   STRIPE_PRICE_<PLAN_ID>_<CURRENCY>
# Where PLAN_ID is upper-cased with underscores (PRO_PLAYER, PRO_AGENCY).
# Currency: USD or EUR.
# When unset, the checkout falls back to creating an ad-hoc `price_data`
# in-line — fine for dev / preview, NOT for production analytics.
STRIPE_PRICE_PRO_PLAYER_USD=
STRIPE_PRICE_PRO_PLAYER_EUR=
STRIPE_PRICE_PRO_AGENCY_USD=
STRIPE_PRICE_PRO_AGENCY_EUR=

# ============================================================
# Billing — Mercado Pago (ARS market)
# ============================================================

# Server-only access token. Use APP_USR-* of a TEST USER in dev.
MP_ACCESS_TOKEN=

# Optional: only needed for Bricks / client-side card tokenization.
MP_PUBLIC_KEY=

# Webhook signature secret from MP dashboard → Webhooks → Signing secret.
# When unset, the webhook handler logs a loud warning and skips signature
# verification (dev only — NEVER ship to production without setting this).
MP_WEBHOOK_SECRET=
