# ============================================================
# 'BallersHub — environment variables (template)
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# ----- Supabase (existing) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ----- Database (Drizzle / Postgres) -----
DATABASE_URL=

# ----- Resend (email) -----
RESEND_API_KEY=

# ----- App -----
# Used to build success_url / back_urls — must match deployed URL in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Billing — Stripe (USD / EUR markets)
# ============================================================

# Server-only keys. Use restricted API keys (rk_...) in production with the
# minimum permissions required (Checkout, Customers, Subscriptions read/write).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional public key — only needed when integrating Stripe Elements client-side.
# The hosted Checkout flow we use today does NOT require this.
STRIPE_PUBLISHABLE_KEY=

# Pre-provisioned Stripe Prices (yearly, recurring). Format:
#   STRIPE_PRICE_<PLAN_ID>_<CURRENCY>
# Where PLAN_ID is upper-cased with underscores (PRO_PLAYER, PRO_AGENCY).
# Currency: USD or EUR.
# When unset, the checkout falls back to creating an ad-hoc `price_data`
# in-line — fine for dev / preview, NOT for production analytics.
STRIPE_PRICE_PRO_PLAYER_USD=
STRIPE_PRICE_PRO_PLAYER_EUR=
STRIPE_PRICE_PRO_AGENCY_USD=
STRIPE_PRICE_PRO_AGENCY_EUR=

# ============================================================
# Billing — Mercado Pago (ARS market)
# ============================================================

# Server-only access token. Use APP_USR-* of a TEST USER in dev.
MP_ACCESS_TOKEN=

# Optional: only needed for Bricks / client-side card tokenization.
MP_PUBLIC_KEY=

# Webhook signature secret from MP dashboard → Webhooks → Signing secret.
# When unset, the webhook handler logs a loud warning and skips signature
# verification (dev only — NEVER ship to production without setting this).
MP_WEBHOOK_SECRET=

# Test-mode payer override. With a TEST access token MP rejects
# `payer_email` values that aren't a registered MP test user. Set this
# to the email of your MP test buyer (created via MCP `create_test_user`
# or the dashboard) so checkout creation succeeds in preview/dev. In
# production (live token) leave empty — the real user email is forwarded.
MP_TEST_BUYER_EMAIL=

# Pre-provisioned MP `preapproval_plan` ids per (planId × currency).
# Format: MP_PLAN_<PLAN_ID>_<CURRENCY>. Mirror of Stripe Price IDs.
# Provision via: npx tsx scripts/provision-mp-plans.ts
#
# When set, the checkout references the plan so MP honors the 7-day
# trial natively (first charge after day 7). When unset, falls back to
# inline `/preapproval` with NO trial — first charge is immediate. Set
# these for production. Optional in dev.
MP_PLAN_PRO_PLAYER_ARS=
MP_PLAN_PRO_AGENCY_ARS=

# ============================================================
# AI — Vercel AI Gateway ("Auto-completar con Claude", F5.4)
# ============================================================

# AI Gateway API key. On Vercel, OIDC auth works automatically and this can be
# left empty in prod; for LOCAL dev set a key from
# Vercel → [team] → AI Gateway → API Keys. Without it, the translation
# assistant returns a friendly error and manual editing still works.
AI_GATEWAY_API_KEY=

# Optional. Monthly auto-translation regenerations per profile (HANDOFF §5.1).
AI_TRANSLATION_MONTHLY_REGEN_LIMIT=40

# Optional. Gateway model id (default google/gemini-2.5-flash — strong
# multilingual + cheap). Verify ids with
# `curl https://ai-gateway.vercel.sh/v1/models` — never hardcode from memory.
AI_TRANSLATION_MODEL=google/gemini-2.5-flash
